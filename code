#include <SPI.h>
#include <MFRC522.h>

#define SS_PIN 10
#define RST_PIN 9

MFRC522 rfid(SS_PIN, RST_PIN);

String knownUID = "A1 B2 C3 D4"; // Replace with your card UID

void setup() {
  Serial.begin(9600);
  SPI.begin();
  rfid.PCD_Init();
  Serial.println("Scan your RFID card...");
}

void loop() {
  // Check for new card
  if (!rfid.PICC_IsNewCardPresent()) return;
  if (!rfid.PICC_ReadCardSerial()) return;

  String tag = "";

  // Read UID
  for (byte i = 0; i < rfid.uid.size; i++) {
    tag += String(rfid.uid.uidByte[i] < 0x10 ? " 0" : " ");
    tag += String(rfid.uid.uidByte[i], HEX);
  }

  tag.toUpperCase();

  Serial.print("Card UID:");
  Serial.println(tag);

  // Check if authorized
  if (tag.substring(1) == knownUID) {
    Serial.println("Attendance Marked ✔");
  } else {
    Serial.println("Unknown Card ❌");
  }

  delay(2000);
}
